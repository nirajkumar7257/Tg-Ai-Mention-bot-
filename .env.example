# ---- TELEGRAM BOT CONFIGURATION ----
# BotFather se mila hua aapka asli Telegram Bot Token yahan aayega
TELEGRAM_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# ---- GOOGLE GEMINI AI CONFIGURATION ----
# Google AI Studio (://google.com) se mili hui free API Key yahan aayega
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# ---- HEROKU WEBHOOK CONFIGURATION ----
# Jo unique naam aapne Heroku par app banate waqt rakha hai (Bina https:// ke)
HEROKU_APP_NAME=your-heroku-app-name

# (Optional) Local testing ke liye port, Heroku isko automatic handle karta hai
PORT=8443

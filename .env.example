# ═══════════════════════════════════════════════════════════════
# TG AI MENTION BOT - ENVIRONMENT VARIABLES CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# ---- TELEGRAM BOT CONFIGURATION ----
# BotFather से मिला हुआ आपका असली Telegram Bot Token
# प्राप्त करें: https://t.me/BotFather पर /newbot से
TELEGRAM_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# ---- GOOGLE GEMINI AI CONFIGURATION ----
# Google AI Studio से मिली हुई free Gemini API Key
# प्राप्त करें: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# ---- BOT OWNER ID ----
# आपका Telegram User ID (Numeric format में)
# प्राप्त करें: @MissRose_bot पर /id कमांड से या @userinfobot से
OWNER_ID=123456789

# ---- HEROKU CONFIGURATION ----
# Heroku पर दिया गया आपका unique app name (https:// के बिना)
# Example: my-telegram-bot (अगर पूरा URL है: https://my-telegram-bot.herokuapp.com)
HEROKU_APP_NAME=your-heroku-app-name

# Server port (Local testing के लिए, Heroku automatically handle करता है)
PORT=8443

# ---- SUPPORT & SOCIAL LINKS ----
# आपका Telegram Support Channel या Group का link
# Example: https://t.me/your_channel_name
SUPPORT_LINK=https://t.me/your_channel_name

# ═══════════════════════════════════════════════════════════════
# ⚠️ IMPORTANT: यह .env.example file है
# 1. इसे copy करके .env नाम से नया file बनाएं
# 2. सभी values को अपने actual values से replace करें
# 3. NEVER .env को GitHub पर commit न करें (already in .gitignore)
# ═══════════════════════════════════════════════════════════════
